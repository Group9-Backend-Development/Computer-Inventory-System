NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/computer_inventory
# Vercel: set MONGODB_URI (and other vars) under Project Settings > Environment Variables for Production.
# Atlas: allow 0.0.0.0/0 in Network Access for serverless, or use a dedicated prod cluster.
SUPABASE_URL=change-me-in-production
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DOCUMENTS_BUCKET=documents
JWT_SECRET=change-me-in-production
# Required on Vercel production (NODE_ENV=production). If unset, login returns 500 after password check.
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:3000
