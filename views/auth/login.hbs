<div class="mx-auto w-full max-w-[420px]">
  <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-[0_1px_3px_rgba(0,0,0,0.06),0_8px_24px_-4px_rgba(15,23,42,0.08)]">
    <header class="mb-8 text-center">
      <h1 class="text-xl font-semibold tracking-tight text-slate-900">{{title}}</h1>
      <p class="mt-2 text-sm leading-relaxed text-slate-600">
        Enter your work email and password to access the dashboard.
      </p>
    </header>

    <form method="post" action="/login" autocomplete="off" class="space-y-5">
      <input type="hidden" name="next" value="{{next}}" />
      {{#if error}}
        <div
          class="rounded-lg border border-red-100 bg-red-50 px-3 py-3 text-center text-sm text-red-900"
          role="alert"
        >
          {{error}}
        </div>
      {{/if}}

      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-slate-700" for="signin-email">Work email</label>
        <input
          id="signin-email"
          class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-[15px] text-slate-900 shadow-inner outline-none transition placeholder:text-slate-400 focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
          type="email"
          name="email"
          value="{{email}}"
          required
          autocomplete="username"
          placeholder="you@organization.edu"
          spellcheck="false"
        />
      </div>

      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-slate-700" for="signin-password">Password</label>
        <input
          id="signin-password"
          class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-[15px] text-slate-900 shadow-inner outline-none transition placeholder:text-slate-400 focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
          type="password"
          name="password"
          required
          autocomplete="current-password"
          placeholder=""
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-700"
      >
        Continue
      </button>
    </form>

    <p class="mt-8 text-center text-xs leading-relaxed text-slate-500">
      This system is restricted to authorized personnel.<br />Do not share your credentials.
    </p>
  </div>

  <p class="mt-8 text-center text-xs text-slate-400">&copy; Computer Inventory</p>
</div>
