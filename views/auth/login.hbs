<section class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-2">
  <div class="rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-sky-300">Secure access</p>
    <h1 class="mt-2 text-3xl font-extrabold text-slate-800">{{title}}</h1>
    <p class="mt-3 text-slate-600">Sign in to manage assets, check-in/check-out activity, and reporting tools.</p>
    <p class="mt-5 text-sm text-slate-500">API login endpoint remains <code class="rounded bg-sky-50 px-1.5 py-0.5 text-sky-700">POST /api/auth/login</code>.</p>
  </div>

  <form class="rounded-2xl border border-sky-200 bg-white p-6 shadow-sm" method="post" action="#">
    <label class="mb-4 block text-sm font-medium text-slate-700">
      Email
      <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800 outline-none ring-0 transition focus:border-sky-400 focus:ring-2 focus:ring-sky-500/30" type="email" name="email" autocomplete="username" />
    </label>
    <label class="mb-6 block text-sm font-medium text-slate-700">
      Password
      <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800 outline-none ring-0 transition focus:border-sky-400 focus:ring-2 focus:ring-sky-500/30" type="password" name="password" autocomplete="current-password" />
    </label>
    <button class="w-full rounded-lg border border-sky-300/60 bg-gradient-to-r from-sky-500 to-blue-700 px-4 py-2.5 font-semibold text-white opacity-70" type="submit" disabled>Sign in</button>
    <p class="mt-3 text-xs text-slate-500">UI authentication wiring will be enabled after backend auth integration.</p>
  </form>
</section>
