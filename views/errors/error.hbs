<section class="mx-auto max-w-2xl space-y-5 rounded-2xl border border-amber-200/90 bg-white px-6 py-10 text-center shadow-sm sm:px-10">
  <p class="text-sm font-semibold uppercase tracking-wide text-amber-800/90">Error</p>
  <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{{status}} — Something went wrong</h1>
  <p class="text-pretty text-slate-600">{{message}}</p>
  <p>
    <a class="inline-flex items-center justify-center rounded-lg bg-brand-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-900" href="/">Back to dashboard</a>
  </p>
</section>
