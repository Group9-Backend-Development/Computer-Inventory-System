<section class="space-y-6">
  <div class="rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
    <p class="text-xs font-bold uppercase tracking-[0.2em] text-sky-300">Inventory management platform</p>
    <h1 class="mt-2 text-3xl font-extrabold text-slate-800 sm:text-4xl">{{title}}</h1>
    <p class="mt-3 max-w-2xl text-slate-600">Track hardware, assignments, and reports in one place with a clean dashboard workflow.</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a class="rounded-lg border border-sky-300 bg-gradient-to-r from-sky-500 to-blue-600 px-4 py-2 font-semibold text-white transition hover:from-sky-400 hover:to-blue-500" href="/items">Browse inventory</a>
      <a class="rounded-lg border border-slate-300 bg-slate-100 px-4 py-2 font-semibold text-slate-700 transition hover:border-sky-300 hover:bg-slate-50" href="/reports">Open reports</a>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <article class="rounded-xl border border-sky-200 bg-white p-4">
      <p class="text-sm text-slate-500">Inventory status</p>
      <p class="mt-1 text-2xl font-bold text-slate-800">1,248</p>
      <p class="text-xs text-emerald-300">+4.6% this month</p>
    </article>
    <article class="rounded-xl border border-sky-200 bg-white p-4">
      <p class="text-sm text-slate-500">Checked out</p>
      <p class="mt-1 text-2xl font-bold text-slate-800">387</p>
      <p class="text-xs text-sky-300">Active assignments</p>
    </article>
    <article class="rounded-xl border border-sky-200 bg-white p-4">
      <p class="text-sm text-slate-500">Pending review</p>
      <p class="mt-1 text-2xl font-bold text-slate-800">18</p>
      <p class="text-xs text-amber-300">Needs inspection</p>
    </article>
  </div>
</section>
