<section class="space-y-8">
  <header class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 bg-gradient-to-br from-brand-700/90 to-brand-900 px-6 py-8 sm:px-8 sm:py-10">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/75">Overview</p>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">{{title}}</h1>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-white/90 sm:text-[15px]">
        Assets, assignments, and reporting in one place. Use shortcuts below to jump to common tasks.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-brand-900 shadow-sm ring-1 ring-white/40 transition hover:bg-brand-50"
          href="/items"
        >
          Browse inventory
        </a>
        <a
          class="inline-flex items-center justify-center rounded-lg border border-white/35 bg-transparent px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10"
          href="/reports"
        >
          Open reports
        </a>
      </div>
    </div>

    <div class="grid gap-px bg-slate-100 sm:grid-cols-3">
      <article class="bg-white px-6 py-5">
        <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Assets on record</h2>
        <p class="mt-2 text-3xl font-bold tabular-nums text-slate-900">{{inventorySummary.total}}</p>
        <p class="mt-1 text-sm text-slate-600">Total active inventory items</p>
      </article>
      <article class="bg-white px-6 py-5">
        <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Deployed</h2>
        <p class="mt-2 text-3xl font-bold tabular-nums text-slate-900">{{inventorySummary.deployed}}</p>
        <p class="mt-1 text-sm text-slate-600">Currently in use</p>
      </article>
      <article class="border-t border-slate-100 bg-white px-6 py-5 sm:border-t-0">
        <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Maintenance</h2>
        <p class="mt-2 text-3xl font-bold tabular-nums text-slate-900">{{maintenanceTotal}}</p>
        <p class="mt-1 text-sm text-slate-600">Items under service</p>
      </article>
    </div>

    {{#unless (eq inventorySummary.total 0)}}
      <footer class="bg-slate-50/90 px-6 py-4 sm:px-8">
        <p class="text-center text-xs text-slate-500">
          Available elsewhere:
          <span class="tabular-nums font-semibold text-slate-700">{{inventorySummary.available}}</span>
          not assigned
        </p>
      </footer>
    {{/unless}}
  </header>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <a href="/transactions/checkout" class="group rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-700/35 hover:shadow-md">
      <span class="text-sm font-semibold text-slate-900 group-hover:text-brand-900">Check out</span>
      <p class="mt-2 text-xs leading-relaxed text-slate-600">Assign gear and attach approval documents.</p>
    </a>
    <a href="/transactions/checkin" class="group rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-700/35 hover:shadow-md">
      <span class="text-sm font-semibold text-slate-900 group-hover:text-brand-900">Check in</span>
      <p class="mt-2 text-xs leading-relaxed text-slate-600">Close assignments with inspection files.</p>
    </a>
    <a href="/items/new" class="group rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-700/35 hover:shadow-md">
      <span class="text-sm font-semibold text-slate-900 group-hover:text-brand-900">Add item</span>
      <p class="mt-2 text-xs leading-relaxed text-slate-600">Register new hardware in the catalog.</p>
    </a>
    <a href="/users" class="group rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-700/35 hover:shadow-md">
      <span class="text-sm font-semibold text-slate-900 group-hover:text-brand-900">Users</span>
      <p class="mt-2 text-xs leading-relaxed text-slate-600">Roles, access, and status for staff.</p>
    </a>
  </div>
</section>
