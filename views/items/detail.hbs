<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>

  <div class="grid gap-4 md:grid-cols-2 text-slate-700">
    <div><strong>Item ID:</strong> {{item.itemId}}</div>
    <div><strong>Serial Number:</strong> {{item.serialNumber}}</div>
    <div><strong>Brand:</strong> {{item.brand}}</div>
    <div><strong>Model:</strong> {{item.model}}</div>
    <div><strong>Classification:</strong> {{item.classification}}</div>
    <div><strong>Category:</strong> {{item.category}}</div>
    <div><strong>Status:</strong> {{item.status}}</div>
    <div><strong>Date Acquired:</strong> {{item.dateAcquired}}</div>
  </div>

  {{#if currentAssignment}}
    <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      <strong>Current assignee:</strong> {{currentAssignment.assigneeName}}
      <span class="mx-2 text-amber-400">·</span>
      Checked out {{currentAssignment.checkedOutAt}}
      <span class="mx-2 text-amber-400">·</span>
      {{currentAssignment.durationLabel}}
    </div>
  {{/if}}

  <div class="grid gap-4 lg:grid-cols-2">
    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-slate-800">Recent transactions</h2>
      <ol class="space-y-2">
        {{#if recentTransactions.length}}
          {{#each recentTransactions}}
            <li class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
              <div class="font-semibold capitalize">{{this.type}} · {{this.createdAtLabel}}</div>
              <div>Assignee: {{this.assigneeName}}</div>
              {{#if this.documentUrl}}
                <a class="text-sky-700 hover:underline" href="{{this.documentUrl}}" target="_blank" rel="noopener">{{this.documentName}}</a>
              {{/if}}
            </li>
          {{/each}}
        {{else}}
          <li class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-500">No transactions yet.</li>
        {{/if}}
      </ol>
    </section>

    <section class="space-y-3">
      <h2 class="text-lg font-semibold text-slate-800">Usage history</h2>
      <ol class="space-y-2">
        {{#if assignments.length}}
          {{#each assignments}}
            <li class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
              <div class="font-semibold">{{this.assigneeName}} · {{this.statusLabel}}</div>
              <div>{{this.checkedOutAt}} to {{#if this.checkedInAt}}{{this.checkedInAt}}{{else}}now{{/if}}</div>
              <div class="text-slate-500">{{this.durationLabel}}</div>
            </li>
          {{/each}}
        {{else}}
          <li class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-500">No assignment history yet.</li>
        {{/if}}
      </ol>
    </section>
  </div>

  <div class="flex flex-wrap gap-3">
    <a class="rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300" href="/items/{{item._id}}/history">View history</a>
    <a class="rounded-lg border border-sky-300 bg-sky-100 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200" href="/items/{{item._id}}/edit">Edit item</a>

    <form method="POST" action="/items/{{item._id}}/delete">
      <button
        type="submit"
        class="rounded-lg border border-red-300 bg-red-100 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-200"
      >
        Delete item
      </button>
    </form>

    <a class="rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300" href="/items">Back to items</a>
  </div>
</section>
