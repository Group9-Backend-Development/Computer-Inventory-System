<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
  <p class="text-slate-600">Item <code class="rounded bg-sky-50 px-1.5 py-0.5 text-sky-700">{{id}}</code></p>
  <div class="flex flex-wrap gap-3">
    <a class="rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300" href="/items/{{id}}/history">View history</a>
    <a class="rounded-lg border border-sky-300 bg-sky-100 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200" href="/items/{{id}}/edit">Edit item</a>
  </div>
</section>
