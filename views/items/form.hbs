<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
  <header class="border-b border-slate-100 pb-6">
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Catalog</p>
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{{title}}</h1>
    <p class="mt-2 max-w-xl text-sm text-slate-600">
      Required fields enforce consistent IDs and classifications. Matching serials and models help auditors trace assets quickly.
    </p>
  </header>

  <form
    method="POST"
    action="{{#if item}}/items/{{item._id}}/edit{{else}}/items{{/if}}"
    class="mt-8 space-y-10"
  >
    <fieldset class="rounded-xl border border-slate-100 bg-slate-50/50 p-5 sm:p-6">
      <legend class="px-1 text-sm font-semibold text-slate-900">Identification</legend>
      <p class="-mt-1 mb-6 text-xs text-slate-500">Tags used on labels and in search.</p>
      <div class="grid gap-5 md:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Item ID</span>
          <input
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm font-mono text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            type="text"
            name="itemId"
            value="{{item.itemId}}"
            required
            autocomplete="off"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Serial number</span>
          <input
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm font-mono text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            type="text"
            name="serialNumber"
            value="{{item.serialNumber}}"
            required
            autocomplete="off"
          />
        </label>
      </div>
    </fieldset>

    <fieldset class="rounded-xl border border-slate-100 bg-slate-50/50 p-5 sm:p-6">
      <legend class="px-1 text-sm font-semibold text-slate-900">Product</legend>
      <p class="-mt-1 mb-6 text-xs text-slate-500">What the hardware is classified as operationally.</p>
      <div class="grid gap-5 md:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Brand</span>
          <input
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            type="text"
            name="brand"
            value="{{item.brand}}"
            required
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Model</span>
          <input
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            type="text"
            name="model"
            value="{{item.model}}"
            required
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Classification</span>
          <select
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            name="classification"
            required
          >
            <option value="">Select classification</option>
            <option value="Computer" {{#if (eq item.classification "Computer")}}selected{{/if}}>Computer</option>
            <option value="Peripheral" {{#if (eq item.classification "Peripheral")}}selected{{/if}}>Peripheral</option>
          </select>
        </label>
        <label class="block md:col-span-2">
          <span class="text-sm font-medium text-slate-700">Category</span>
          <input
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            type="text"
            name="category"
            value="{{item.category}}"
            placeholder="Laptop, desktop, monitor..."
            required
          />
        </label>
      </div>
    </fieldset>

    <fieldset class="rounded-xl border border-slate-100 bg-slate-50/50 p-5 sm:p-6">
      <legend class="px-1 text-sm font-semibold text-slate-900">Lifecycle</legend>
      <p class="-mt-1 mb-6 text-xs text-slate-500">Operational state and procurement date drive reports.</p>
      <div class="grid gap-5 md:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Status</span>
          <select
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            name="status"
            required
          >
            <option value="Available" {{#if (eq item.status "Available")}}selected{{/if}}>Available</option>
            <option value="In-Use" {{#if (eq item.status "In-Use")}}selected{{/if}}>In-Use</option>
            <option value="Maintenance" {{#if (eq item.status "Maintenance")}}selected{{/if}}>Maintenance</option>
            <option value="Retired" {{#if (eq item.status "Retired")}}selected{{/if}}>Retired</option>
          </select>
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Date acquired</span>
          <input
            class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
            type="date"
            name="dateAcquired"
            value="{{item.dateAcquired}}"
            required
          />
        </label>
      </div>
    </fieldset>

    <div class="flex flex-wrap gap-3 border-t border-slate-100 pt-6">
      <button
        type="submit"
        class="rounded-lg bg-brand-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-700"
      >
        {{#if item}}Save changes{{else}}Create item{{/if}}
      </button>

      <a
        href="/items"
        class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-400 hover:bg-slate-50"
      >
        Cancel
      </a>
    </div>
  </form>
</section>
