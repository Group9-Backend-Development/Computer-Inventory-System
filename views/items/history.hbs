<section class="space-y-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
  <header class="flex flex-col gap-4 border-b border-slate-100 pb-6 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <nav class="text-xs font-medium text-slate-500" aria-label="Breadcrumb">
        <a href="/items" class="text-brand-700 hover:underline">Inventory</a>
        <span aria-hidden="true"> / </span>
        <a href="/items/{{item._id}}" class="font-mono text-slate-700">{{item.itemId}}</a>
      </nav>
      <h1 class="mt-3 text-2xl font-bold tracking-tight text-slate-900">{{title}}</h1>
      <p class="mt-2 text-sm text-slate-600">{{item.brand}} {{item.model}}</p>
    </div>
    <a
      class="inline-flex shrink-0 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50"
      href="/items/{{item._id}}"
    >
      Back to detail
    </a>
  </header>

  <section class="space-y-4" aria-labelledby="assignments-history-heading">
    <h2 id="assignments-history-heading" class="text-lg font-semibold text-slate-900">Assignment history</h2>
    <div class="overflow-hidden rounded-xl border border-slate-200 shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-[720px] w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">
            <tr>
              <th scope="col" class="px-4 py-3">Assignee</th>
              <th scope="col" class="px-4 py-3">Checked out</th>
              <th scope="col" class="px-4 py-3">Checked in</th>
              <th scope="col" class="px-4 py-3">Duration</th>
              <th scope="col" class="px-4 py-3">Documents</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            {{#if assignments.length}}
              {{#each assignments}}
                <tr class="hover:bg-slate-50/80">
                  <td class="px-4 py-3.5">{{this.assigneeName}}</td>
                  <td class="whitespace-nowrap px-4 py-3.5 text-slate-700">{{this.checkedOutAt}}</td>
                  <td class="whitespace-nowrap px-4 py-3.5 text-slate-700">{{#if this.checkedInAt}}{{this.checkedInAt}}{{else}}Active{{/if}}</td>
                  <td class="px-4 py-3.5">{{this.durationLabel}}</td>
                  <td class="px-4 py-3.5">
                    <div class="flex flex-wrap gap-3">
                      {{#if this.checkoutDocumentUrl}}
                        <a class="font-medium text-brand-700 underline-offset-2 hover:underline" href="{{this.checkoutDocumentUrl}}" target="_blank" rel="noopener noreferrer">Checkout doc</a>
                      {{/if}}
                      {{#if this.checkinDocumentUrl}}
                        <a class="font-medium text-brand-700 underline-offset-2 hover:underline" href="{{this.checkinDocumentUrl}}" target="_blank" rel="noopener noreferrer">Check-in doc</a>
                      {{/if}}
                    </div>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr>
                <td colspan="5" class="px-6 py-14 text-center text-sm text-slate-500">No previous assignments recorded.</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="space-y-4" aria-labelledby="transaction-log-heading">
    <h2 id="transaction-log-heading" class="text-lg font-semibold text-slate-900">Transaction log</h2>
    <ol class="space-y-3">
      {{#if transactions.length}}
        {{#each transactions}}
          <li class="rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm transition hover:border-slate-300">
            <div class="flex flex-wrap gap-x-2 gap-y-1 text-sm text-slate-800">
              <strong class="capitalize">{{this.type}}</strong>
              <span class="text-slate-300" aria-hidden="true">|</span>
              <span>{{this.createdAtLabel}}</span>
              <span class="text-slate-300" aria-hidden="true">|</span>
              <span>Assignee {{this.assigneeName}}</span>
              <span class="text-slate-300" aria-hidden="true">|</span>
              <span>By {{this.performedByName}}</span>
            </div>
            {{#if this.note}}
              <p class="mt-2 border-t border-slate-50 pt-2 text-sm text-slate-600">{{this.note}}</p>
            {{/if}}
            {{#if this.documentUrl}}
              <a class="mt-2 inline-block text-sm font-medium text-brand-700 underline-offset-2 hover:underline" href="{{this.documentUrl}}" target="_blank" rel="noopener noreferrer">{{this.documentName}}</a>
            {{/if}}
          </li>
        {{/each}}
      {{else}}
        <li class="rounded-xl border border-dashed border-slate-200 px-4 py-8 text-center text-sm text-slate-500">No transactions yet.</li>
      {{/if}}
    </ol>
  </section>
</section>
