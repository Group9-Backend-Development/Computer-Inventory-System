<section class="space-y-5 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
      <p class="mt-1 text-slate-600">{{item.itemId}} · {{item.brand}} {{item.model}}</p>
    </div>
    <a class="rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300" href="/items/{{item._id}}">Back to item</a>
  </div>

  <section class="space-y-3">
    <h2 class="text-lg font-semibold text-slate-800">Historical view</h2>
    <div class="overflow-x-auto rounded-xl border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-4 py-3 text-left font-semibold">Assignee</th>
            <th class="px-4 py-3 text-left font-semibold">Checked out</th>
            <th class="px-4 py-3 text-left font-semibold">Checked in</th>
            <th class="px-4 py-3 text-left font-semibold">Duration</th>
            <th class="px-4 py-3 text-left font-semibold">Documents</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white text-slate-700">
          {{#if assignments.length}}
            {{#each assignments}}
              <tr>
                <td class="px-4 py-3">{{this.assigneeName}}</td>
                <td class="px-4 py-3">{{this.checkedOutAt}}</td>
                <td class="px-4 py-3">{{#if this.checkedInAt}}{{this.checkedInAt}}{{else}}Active{{/if}}</td>
                <td class="px-4 py-3">{{this.durationLabel}}</td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    {{#if this.checkoutDocumentUrl}}
                      <a class="text-sky-700 hover:underline" href="{{this.checkoutDocumentUrl}}" target="_blank" rel="noopener">Checkout</a>
                    {{/if}}
                    {{#if this.checkinDocumentUrl}}
                      <a class="text-sky-700 hover:underline" href="{{this.checkinDocumentUrl}}" target="_blank" rel="noopener">Checkin</a>
                    {{/if}}
                  </div>
                </td>
              </tr>
            {{/each}}
          {{else}}
            <tr>
              <td colspan="5" class="px-4 py-6 text-center text-slate-500">No previous assignments found.</td>
            </tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </section>

  <section class="space-y-3">
    <h2 class="text-lg font-semibold text-slate-800">Transaction log</h2>
    <ol class="space-y-3">
      {{#if transactions.length}}
        {{#each transactions}}
          <li class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
            <div class="flex flex-wrap items-center gap-2">
              <strong class="capitalize">{{this.type}}</strong>
              <span class="text-slate-400">·</span>
              <span>{{this.createdAtLabel}}</span>
              <span class="text-slate-400">·</span>
              <span>Assignee: {{this.assigneeName}}</span>
              <span class="text-slate-400">·</span>
              <span>By: {{this.performedByName}}</span>
            </div>
            {{#if this.note}}
              <p class="mt-2 text-slate-600">{{this.note}}</p>
            {{/if}}
            {{#if this.documentUrl}}
              <a class="mt-2 inline-block text-sky-700 hover:underline" href="{{this.documentUrl}}" target="_blank" rel="noopener">{{this.documentName}}</a>
            {{/if}}
          </li>
        {{/each}}
      {{else}}
        <li class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm text-slate-500">No transactions yet.</li>
      {{/if}}
    </ol>
  </section>
</section>
