<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
    <a class="rounded-lg border border-sky-300 bg-sky-100 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200" href="/items/new">Add item</a>
  </div>

  <form method="GET" action="/items" class="flex flex-wrap items-end gap-3">
    <div>
      <label class="mb-1 block text-sm font-medium text-slate-700">Filter by status</label>
      <select
        name="status"
        class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800"
      >
        <option value="">All statuses</option>
        <option value="Available" {{#if (eq selectedStatus "Available")}}selected{{/if}}>Available</option>
        <option value="In-Use" {{#if (eq selectedStatus "In-Use")}}selected{{/if}}>In-Use</option>
        <option value="Maintenance" {{#if (eq selectedStatus "Maintenance")}}selected{{/if}}>Maintenance</option>
        <option value="Retired" {{#if (eq selectedStatus "Retired")}}selected{{/if}}>Retired</option>
      </select>
    </div>

    <div class="flex gap-2">
      <button
        type="submit"
        class="rounded-lg border border-sky-300 bg-sky-100 px-4 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200"
      >
        Apply
      </button>

      <a
        href="/items"
        class="rounded-lg border border-slate-300 bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300"
      >
        Clear
      </a>
    </div>
  </form>

  <div class="overflow-x-auto rounded-xl border border-slate-200">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-slate-600">
        <tr>
          <th class="px-4 py-3 text-left font-semibold">Item ID</th>
          <th class="px-4 py-3 text-left font-semibold">Brand</th>
          <th class="px-4 py-3 text-left font-semibold">Model</th>
          <th class="px-4 py-3 text-left font-semibold">Classification</th>
          <th class="px-4 py-3 text-left font-semibold">Category</th>
          <th class="px-4 py-3 text-left font-semibold">Status</th>
          <th class="px-4 py-3 text-left font-semibold">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white text-slate-700">
        {{#if items.length}}
          {{#each items}}
            <tr>
              <td class="px-4 py-3">{{this.itemId}}</td>
              <td class="px-4 py-3">{{this.brand}}</td>
              <td class="px-4 py-3">{{this.model}}</td>
              <td class="px-4 py-3">{{this.classification}}</td>
              <td class="px-4 py-3">{{this.category}}</td>
              <td class="px-4 py-3">{{this.status}}</td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <a href="/items/{{this._id}}" class="text-sky-700 hover:underline">View</a>
                  <a href="/items/{{this._id}}/edit" class="text-amber-700 hover:underline">Edit</a>
                  <form method="POST" action="/items/{{this._id}}/delete" style="display:inline;">
                    <button type="submit" class="text-red-700 hover:underline">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="7" class="px-4 py-6 text-center text-slate-500">No items found.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</section>