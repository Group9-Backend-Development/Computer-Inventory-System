<section class="space-y-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Assets</p>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{{title}}</h1>
      <p class="mt-2 text-sm leading-relaxed text-slate-600">
        View identifiers, classifications, and lifecycle status for hardware in scope. Edit records or remove lines that should no longer appear in searches.
      </p>
    </div>
    <a
      class="inline-flex shrink-0 items-center justify-center rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm ring-1 ring-brand-700/10 transition hover:bg-brand-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-700"
      href="/items/new"
    >
      Add item
    </a>
  </div>

  <dl class="grid gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-slate-50/70 px-4 py-4">
      <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Catalog total</dt>
      <dd class="mt-1 text-2xl font-semibold tabular-nums text-slate-900">{{totalCount}}</dd>
      <dd class="mt-1 text-xs text-slate-500">Non-deleted items</dd>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50/70 px-4 py-4">
      <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Shown</dt>
      <dd class="mt-1 text-2xl font-semibold tabular-nums text-slate-900">{{items.length}}</dd>
      <dd class="mt-1 text-xs text-slate-500">After filters</dd>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50/70 px-4 py-4">
      <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Status filter</dt>
      <dd class="mt-1 text-sm font-semibold text-slate-900">
        {{#if selectedStatus}}{{selectedStatus}}{{else}}All statuses{{/if}}
      </dd>
      <dd class="mt-1 text-xs text-slate-500">Current list scope</dd>
    </div>
  </dl>

  <div class="rounded-xl border border-slate-200 bg-slate-50/80 p-5">
    <h2 class="text-sm font-semibold text-slate-900">Refine results</h2>
    <p class="mt-1 text-sm text-slate-600">Limit the table by asset status without changing underlying records.</p>
    <form method="GET" action="/items" class="mt-4 flex flex-wrap items-end gap-4">
      <div class="min-w-[12rem] flex-1 sm:max-w-xs">
        <label for="status-filter" class="mb-1.5 block text-sm font-medium text-slate-700">Status</label>
        <select
          id="status-filter"
          name="status"
          class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
        >
          <option value="">All statuses</option>
          <option value="Available" {{#if (eq selectedStatus "Available")}}selected{{/if}}>Available</option>
          <option value="In-Use" {{#if (eq selectedStatus "In-Use")}}selected{{/if}}>In-Use</option>
          <option value="Maintenance" {{#if (eq selectedStatus "Maintenance")}}selected{{/if}}>Maintenance</option>
          <option value="Retired" {{#if (eq selectedStatus "Retired")}}selected{{/if}}>Retired</option>
        </select>
      </div>
      <div class="flex flex-wrap gap-2">
        <button
          type="submit"
          class="rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-900"
        >
          Apply filter
        </button>
        <a
          href="/items"
          class="rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-400 hover:bg-slate-50"
        >
          Reset
        </a>
      </div>
    </form>
  </div>

  <div>
    <div class="mb-3 flex flex-wrap items-end justify-between gap-2">
      <h2 class="text-sm font-semibold text-slate-900">Asset list</h2>
      <p class="text-xs text-slate-500">Click a row action to view or edit detail.</p>
    </div>
    <div class="overflow-hidden rounded-xl border border-slate-200 shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-[720px] w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">
            <tr>
              <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Item ID</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Brand</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Model</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Classification</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Category</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Status</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3 text-right lg:px-5">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white text-slate-800">
            {{#if items.length}}
              {{#each items}}
                <tr class="transition-colors hover:bg-slate-50/80">
                  <td class="px-4 py-3.5 align-middle font-mono text-sm font-medium lg:px-5">{{this.itemId}}</td>
                  <td class="px-4 py-3.5 align-middle text-slate-700 lg:px-5">{{this.brand}}</td>
                  <td class="px-4 py-3.5 align-middle text-slate-700 lg:px-5">{{this.model}}</td>
                  <td class="px-4 py-3.5 align-middle text-slate-700 lg:px-5">{{this.classification}}</td>
                  <td class="px-4 py-3.5 align-middle text-slate-700 lg:px-5">{{this.category}}</td>
                  <td class="px-4 py-3.5 align-middle lg:px-5">
                    {{#if (eq this.status "Available")}}
                      <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 ring-1 ring-emerald-200/80">Available</span>
                    {{else}}
                      {{#if (eq this.status "In-Use")}}
                        <span class="inline-flex rounded-full bg-sky-50 px-2.5 py-0.5 text-xs font-semibold text-sky-800 ring-1 ring-sky-200/80">In-Use</span>
                      {{else}}
                        {{#if (eq this.status "Maintenance")}}
                          <span class="inline-flex rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-900 ring-1 ring-amber-200/80">Maintenance</span>
                        {{else}}
                          {{#if (eq this.status "Retired")}}
                            <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">Retired</span>
                          {{else}}
                            <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">{{this.status}}</span>
                          {{/if}}
                        {{/if}}
                      {{/if}}
                    {{/if}}
                  </td>
                  <td class="px-4 py-3.5 lg:px-5">
                    <div class="flex flex-wrap items-center justify-end gap-2">
                      <a
                        href="/items/{{this._id}}"
                        class="rounded-md border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-700 shadow-sm hover:border-slate-300 hover:bg-slate-50"
                      >
                        View
                      </a>
                      <a
                        href="/items/{{this._id}}/edit"
                        class="rounded-md border border-amber-200 bg-white px-2.5 py-1.5 text-xs font-semibold text-amber-900 shadow-sm hover:bg-amber-50"
                      >
                        Edit
                      </a>
                      {{#if (eq ../currentUser.role "admin")}}
                        <form method="POST" action="/items/{{this._id}}/delete" class="inline" data-confirm="Delete this item from the inventory?">
                          <button
                            type="submit"
                            class="rounded-md border border-red-200 bg-white px-2.5 py-1.5 text-xs font-semibold text-red-700 shadow-sm hover:bg-red-50"
                          >
                            Delete
                          </button>
                        </form>
                      {{/if}}
                    </div>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr>
                <td colspan="7" class="px-6 py-16 text-center">
                  {{#if (eq totalCount 0)}}
                    <p class="text-base font-semibold text-slate-900">No items yet</p>
                    <p class="mt-2 max-w-md mx-auto text-sm text-slate-600">
                      Records you add will appear here with filters, status badges, and quick actions for maintenance.
                    </p>
                    <a
                      href="/items/new"
                      class="mt-6 inline-flex items-center rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-900"
                    >
                      Add your first item
                    </a>
                  {{else}}
                    <p class="text-base font-semibold text-slate-900">No matching items</p>
                    <p class="mt-2 max-w-md mx-auto text-sm text-slate-600">
                      Nothing currently matches this status filter. Adjust the filter or clear it to see the full catalog.
                    </p>
                    <a
                      href="/items"
                      class="mt-6 inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50"
                    >
                      Clear filter and show all
                    </a>
                  {{/if}}
                </td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
