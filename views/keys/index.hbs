<section class="space-y-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
  <div>
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Integrations</p>
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{{title}}</h1>
    <p class="mt-1 text-slate-600">Generate keys for integrations. Secrets are stored as a hash only. <strong>Revoke</strong> sets status to <strong>Revoked</strong> for history (the credential no longer works for API calls).</p>
  </div>

  {{#if newPlainKey}}
    <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-4 shadow-sm">
      <p class="text-sm font-semibold text-amber-900">Copy your new API key now</p>
      <p class="mt-1 text-sm text-amber-800">Store it securely. It will not be shown again.</p>
      <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-center">
        <label class="sr-only" for="new-api-key-plain">New API key</label>
        <input
          id="new-api-key-plain"
          type="text"
          readonly
          class="flex-1 rounded-lg border border-amber-200 bg-white px-3 py-2 font-mono text-sm text-slate-900 outline-none ring-amber-400/40 focus:ring-2"
          value="{{newPlainKey}}"
        />
        <button
          type="button"
          class="rounded-lg border border-amber-300 bg-white px-4 py-2 text-sm font-semibold text-amber-900 shadow-sm transition hover:bg-amber-100"
          data-copy-target="new-api-key-plain"
        >
          Copy
        </button>
      </div>
    </div>
  {{/if}}

  <form action="/keys/generate" method="post" class="rounded-xl border border-slate-200 bg-slate-50 p-4">
    <h2 class="text-sm font-semibold text-slate-800">Create a new key</h2>
    <p class="mt-1 text-sm text-slate-600">Optionally label the key so you remember which integration uses it.</p>
    <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end">
      <label class="flex-1">
        <span class="block text-sm font-medium text-slate-700">Label</span>
        <input
          type="text"
          name="label"
          maxlength="120"
          value=""
          class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
          placeholder="e.g. ticketing integration"
          autocomplete="off"
        />
      </label>
      <button type="submit" class="rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-900">Generate key</button>
    </div>
  </form>

  <div>
    <h2 class="text-sm font-semibold text-slate-800">All keys</h2>
    <div class="mt-3 overflow-hidden rounded-lg border border-slate-200">
      <table class="w-full min-w-[640px] text-left text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-slate-600">
          <tr>
            <th class="px-4 py-3 font-semibold">Label</th>
            <th class="px-4 py-3 font-semibold">Status</th>
            <th class="px-4 py-3 font-semibold">Created</th>
            <th class="px-4 py-3 font-semibold">Created by</th>
            <th class="px-4 py-3 font-semibold">Key ID</th>
            <th class="px-4 py-3 font-semibold"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          {{#if keys.length}}
            {{#each keys}}
              <tr class="{{#if isRevokedUi}}bg-slate-50/90{{/if}}">
                <td class="px-4 py-3 text-slate-800">{{#if label}}{{label}}{{else}}<span class="text-slate-400 italic">No label</span>{{/if}}</td>
                <td class="px-4 py-3">
                  {{#if isRevokedUi}}
                  <div>
                    <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">Revoked</span>
                    {{#if revokedAtLabel}}
                    <span class="mt-1 block text-xs text-slate-500">Updated {{revokedAtLabel}}</span>
                    {{/if}}
                  </div>
                  {{else}}
                  <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 ring-1 ring-emerald-200">Active</span>
                  {{/if}}
                </td>
                <td class="px-4 py-3 text-slate-700">{{createdAtLabel}}</td>
                <td class="px-4 py-3 text-slate-700">{{creatorEmail}}</td>
                <td class="px-4 py-3 font-mono text-xs text-slate-600">{{id}}</td>
                <td class="px-4 py-3 text-right">
                  {{#if isRevokedUi}}
                  <span class="text-xs text-slate-400">&mdash;</span>
                  {{else}}
                  <form action="/keys/{{id}}/revoke" method="post" class="inline-block" data-confirm="Mark this key as Revoked? It will stop working for API calls.">
                    <button type="submit" class="rounded-lg border border-red-200 bg-white px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Revoke</button>
                  </form>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          {{else}}
            <tr>
              <td colspan="6" class="px-4 py-6 text-center text-slate-500">No API keys yet. Generate one above.</td>
            </tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </div>
</section>
