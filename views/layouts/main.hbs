<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{title}} · Computer Inventory</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <meta name="theme-color" content="#0a4b97" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: "#eff8ff",
              100: "#dceeff",
              500: "#1184ff",
              700: "#0a4b97",
              900: "#040b18"
            }
          }
        }
      }
    };
  </script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-sky-50 to-white text-slate-800">
  <div class="min-h-screen">
    {{> nav}}
    <div class="flex min-h-screen flex-1 flex-col lg:ml-72">
      <main class="w-full flex-1 px-4 pb-10 pt-6 sm:px-6 lg:px-8">
        {{{body}}}
      </main>      
    </div>
  </div>
  <script src="/js/main.js" defer></script>
</body>
</html>
