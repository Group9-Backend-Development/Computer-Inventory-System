<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
  <div class="grid gap-4 md:grid-cols-3">
    <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <h2 class="font-semibold text-sky-700">Inventory status</h2>
      <p class="mt-2 text-3xl font-bold text-slate-800">{{inventorySummary.total}}</p>
      <p class="text-sm text-slate-600">Total active assets</p>
      <p class="mt-3 text-sm text-slate-700">In use: <span class="font-semibold">{{inventorySummary.deployed}}</span></p>
      <p class="text-sm text-slate-700">Available: <span class="font-semibold">{{inventorySummary.available}}</span></p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <h2 class="font-semibold text-sky-700">Asset aging</h2>
      <p class="mt-2 text-3xl font-bold text-slate-800">{{agingItems.length}}</p>
      <p class="text-sm text-slate-600">Assets older than 3 years</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <h2 class="font-semibold text-sky-700">User audit</h2>
      <p class="mt-1 text-sm text-slate-600">Review active devices assigned per user and role.</p>
    </article>
  </div>
  <div class="overflow-hidden rounded-lg border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-600">
        <tr>
          <th class="px-4 py-3 font-semibold">Aging asset</th>
          <th class="px-4 py-3 font-semibold">Brand / model</th>
          <th class="px-4 py-3 font-semibold">Date acquired</th>
          <th class="px-4 py-3 font-semibold">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        {{#each agingItems}}
          <tr>
            <td class="px-4 py-3 text-slate-800">{{itemId}}</td>
            <td class="px-4 py-3 text-slate-700">{{brand}} {{model}}</td>
            <td class="px-4 py-3 text-slate-700">{{dateAcquired}}</td>
            <td class="px-4 py-3 text-slate-700">{{status}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</section>
