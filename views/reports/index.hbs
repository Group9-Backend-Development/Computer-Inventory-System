<section class="space-y-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
  <header>
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Insights</p>
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{{title}}</h1>
    <p class="mt-2 max-w-2xl text-sm text-slate-600">
      Summaries are derived from active catalog data. Aging assets use acquisition dates compared to a three-year threshold.
    </p>
  </header>

  <div class="grid gap-4 md:grid-cols-3">
    <article class="rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white px-5 py-6 shadow-sm">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Inventory</h2>
      <p class="mt-3 text-3xl font-bold tabular-nums text-slate-900">{{inventorySummary.total}}</p>
      <p class="mt-1 text-sm text-slate-600">Total tracked assets</p>
      <p class="mt-4 text-sm text-slate-700">In use <span class="font-semibold">{{inventorySummary.deployed}}</span></p>
      <p class="text-sm text-slate-700">Available <span class="font-semibold">{{inventorySummary.available}}</span></p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white px-5 py-6 shadow-sm">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Aging</h2>
      <p class="mt-3 text-3xl font-bold tabular-nums text-slate-900">{{agingItems.length}}</p>
      <p class="mt-1 text-sm text-slate-600">Older than three years</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white px-5 py-6 shadow-sm">
      <h2 class="text-xs font-semibold uppercase tracking-wide text-slate-500">User audit</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">Review assignment patterns and role coverage on the users screen.</p>
      <a class="mt-4 inline-flex text-sm font-semibold text-brand-700 hover:underline" href="/users">Manage users</a>
    </article>
  </div>

  <div class="space-y-4">
    <div>
      <h2 class="text-base font-semibold text-slate-900">User audit</h2>
      <p class="mt-1 text-sm text-slate-600">Select a user to view assets that are currently checked out to that account.</p>
    </div>
    <form method="GET" action="/reports" class="flex flex-col gap-3 rounded-xl border border-slate-200 bg-slate-50 p-4 sm:flex-row sm:items-end">
      <label class="flex-1">
        <span class="block text-sm font-medium text-slate-700">User</span>
        <select
          name="userId"
          class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm outline-none focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20"
          required
        >
          <option value="">Select user</option>
          {{#each users}}
            <option value="{{this.id}}" {{#if (eq this.id @root.selectedUserId)}}selected{{/if}}>{{this.email}}</option>
          {{/each}}
        </select>
      </label>
      <button type="submit" class="rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-brand-900">Run audit</button>
    </form>

    {{#if selectedUserId}}
      <div class="overflow-hidden rounded-xl border border-slate-200 shadow-sm">
        <div class="border-b border-slate-200 bg-white px-4 py-3">
          <p class="text-sm text-slate-700">
            Current assets for
            <strong>{{#if selectedAuditUser}}{{selectedAuditUser.email}}{{else}}selected user{{/if}}</strong>
          </p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-[720px] w-full text-left text-sm">
            <thead class="border-b border-slate-200 bg-slate-50 text-xs font-semibold uppercase tracking-wider text-slate-600">
              <tr>
                <th scope="col" class="whitespace-nowrap px-4 py-3">Item ID</th>
                <th scope="col" class="whitespace-nowrap px-4 py-3">Brand / model</th>
                <th scope="col" class="whitespace-nowrap px-4 py-3">Category</th>
                <th scope="col" class="whitespace-nowrap px-4 py-3">Checked out</th>
                <th scope="col" class="whitespace-nowrap px-4 py-3">Duration</th>
                <th scope="col" class="whitespace-nowrap px-4 py-3">Document</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
              {{#if auditAssets.length}}
                {{#each auditAssets}}
                  <tr class="hover:bg-slate-50/80">
                    <td class="whitespace-nowrap px-4 py-3 font-mono text-slate-900">{{itemId}}</td>
                    <td class="min-w-[12rem] px-4 py-3 text-slate-700">{{brand}} {{model}}</td>
                    <td class="whitespace-nowrap px-4 py-3 text-slate-700">{{category}}</td>
                    <td class="whitespace-nowrap px-4 py-3 text-slate-700">{{checkedOutAt}}</td>
                    <td class="whitespace-nowrap px-4 py-3 text-slate-700">{{durationLabel}}</td>
                    <td class="whitespace-nowrap px-4 py-3">
                      {{#if checkoutDocumentUrl}}
                        <a class="font-medium text-brand-700 underline-offset-2 hover:underline" href="{{checkoutDocumentUrl}}" target="_blank" rel="noopener noreferrer">{{checkoutDocumentName}}</a>
                      {{else}}
                        <span class="text-slate-400">None</span>
                      {{/if}}
                    </td>
                  </tr>
                {{/each}}
              {{else}}
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-sm text-slate-500">No assets are currently assigned to this user.</td>
                </tr>
              {{/if}}
            </tbody>
          </table>
        </div>
      </div>
    {{/if}}
  </div>

  <div>
    <div class="mb-3 flex flex-wrap items-end justify-between gap-2">
      <h2 class="text-base font-semibold text-slate-900">Aging assets</h2>
      <p class="text-xs text-slate-500">Scroll horizontally on small screens.</p>
    </div>
    <div class="overflow-hidden rounded-xl border border-slate-200 shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-[560px] w-full text-left text-sm">
          <thead class="border-b border-slate-200 bg-slate-50 text-xs font-semibold uppercase tracking-wider text-slate-600">
            <tr>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Item ID</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Brand / model</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Date acquired</th>
              <th scope="col" class="whitespace-nowrap px-4 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 bg-white">
            {{#if agingItems.length}}
              {{#each agingItems}}
                <tr class="hover:bg-slate-50/80">
                  <td class="whitespace-nowrap px-4 py-3 font-mono text-slate-900">{{itemId}}</td>
                  <td class="min-w-[12rem] px-4 py-3 text-slate-700">{{brand}} {{model}}</td>
                  <td class="whitespace-nowrap px-4 py-3 text-slate-700">{{#if dateAcquiredDisplay}}{{dateAcquiredDisplay}}{{else}}{{dateAcquired}}{{/if}}</td>
                  <td class="whitespace-nowrap px-4 py-3">{{status}}</td>
                </tr>
              {{/each}}
            {{else}}
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-sm text-slate-500">No assets exceed the aging threshold.</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
