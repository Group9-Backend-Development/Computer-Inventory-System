<section class="space-y-5 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
    <p class="mt-1 text-slate-600">Return an in-use item to available with an inspection document.</p>
  </div>

  <form method="POST" action="/transactions/checkin" enctype="multipart/form-data" class="grid gap-4 md:grid-cols-2">
    <div>
      <label class="mb-1 block text-sm font-medium text-slate-700" for="itemId">In-use item</label>
      <select id="itemId" name="itemId" required class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800">
        <option value="">Select item</option>
        {{#each items}}
          <option value="{{this._id}}">{{this.itemId}} · {{this.brand}} {{this.model}}</option>
        {{/each}}
      </select>
    </div>

    <div>
      <label class="mb-1 block text-sm font-medium text-slate-700" for="performedById">Processed by</label>
      <select id="performedById" name="performedById" required class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800">
        <option value="">Select user</option>
        {{#each users}}
          <option value="{{this._id}}">{{this.email}}</option>
        {{/each}}
      </select>
    </div>

    <div class="md:col-span-2">
      <label class="mb-1 block text-sm font-medium text-slate-700" for="document">Return inspection document</label>
      <input id="document" name="document" type="file" required class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800" />
    </div>

    <div class="md:col-span-2">
      <label class="mb-1 block text-sm font-medium text-slate-700" for="note">Return note</label>
      <textarea id="note" name="note" rows="3" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800"></textarea>
    </div>

    <div class="md:col-span-2 flex flex-wrap gap-3">
      <button type="submit" class="rounded-lg border border-sky-300 bg-sky-100 px-4 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200">Check in item</button>
      <a class="rounded-lg border border-slate-300 bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300" href="/items">Cancel</a>
    </div>
  </form>
</section>
