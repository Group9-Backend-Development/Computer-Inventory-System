<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
  <p class="text-slate-600">Admin-only user creation: email, password, role, enable/disable.</p>
  <div class="grid gap-4 md:grid-cols-2">
    <input class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800" placeholder="Email" />
    <input class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800" placeholder="Password" type="password" />
    <select class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800">
      <option>Admin</option>
      <option>Technician</option>
    </select>
  </div>
</section>
