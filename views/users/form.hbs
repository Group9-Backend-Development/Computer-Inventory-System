<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
  <p class="text-slate-600">Admin-only user creation: email, password, and role.</p>

  <form method="POST" action="/users" class="space-y-4">
    <div class="grid gap-4 md:grid-cols-2">
      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Email</label>
        <input
          class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800"
          type="email"
          name="email"
          value="{{user.email}}"
          placeholder="user@example.com"
          required
        />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Password</label>
        <input
          class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800"
          type="password"
          name="password"
          placeholder="Enter password"
          required
        />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-700">Role</label>
        <select
          class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800"
          name="role"
          required
        >
          <option value="">Select role</option>
          <option value="admin">Admin</option>
          <option value="technician">Technician</option>
        </select>
      </div>
    </div>

    <div class="flex gap-3">
      <button
        type="submit"
        class="rounded-lg border border-sky-300 bg-sky-100 px-4 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200"
      >
        Create User
      </button>

      <a
        href="/users"
        class="rounded-lg border border-slate-300 bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:border-sky-300"
      >
        Cancel
      </a>
    </div>
  </form>
</section>
