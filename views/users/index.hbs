<section class="space-y-4 rounded-2xl border border-sky-200 bg-white p-6 shadow-sm">
  <div class="flex items-center justify-between gap-3">
    <h1 class="text-2xl font-bold text-slate-800">{{title}}</h1>
    <a
      class="rounded-lg border border-sky-300 bg-sky-100 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-200"
      href="/users/new"
    >
      Create user
    </a>
  </div>

  <p class="text-slate-600">
    Admin can manage user roles:
    <span class="font-semibold text-slate-800">Admin</span>
    and
    <span class="font-semibold text-slate-800">Technician</span>.
  </p>

  <div class="overflow-x-auto rounded-xl border border-slate-200">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-slate-600">
        <tr>
          <th class="px-4 py-3 text-left font-semibold">Email</th>
          <th class="px-4 py-3 text-left font-semibold">Role</th>
          <th class="px-4 py-3 text-left font-semibold">Status</th>
          <th class="px-4 py-3 text-left font-semibold">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white text-slate-700">
        {{#if users.length}}
          {{#each users}}
            <tr>
              <td class="px-4 py-3">{{this.email}}</td>
              <td class="px-4 py-3">{{this.role}}</td>
              <td class="px-4 py-3">
                {{#if this.isEnabled}}
                  <span class="font-medium text-green-700">Enabled</span>
                {{else}}
                  <span class="font-medium text-red-700">Disabled</span>
                {{/if}}
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-2">
                  <form method="POST" action="/users/{{this.id}}/role" class="flex items-center gap-2">
                    <select
                      name="role"
                      class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-slate-800"
                      required
                    >
                      <option value="admin" {{#if (eq this.role "admin")}}selected{{/if}}>Admin</option>
                      <option value="technician" {{#if (eq this.role "technician")}}selected{{/if}}>Technician</option>
                    </select>
                    <button
                      type="submit"
                      class="rounded-lg border border-amber-300 bg-amber-100 px-3 py-2 text-sm font-semibold text-amber-700 hover:bg-amber-200"
                    >
                      Update Role
                    </button>
                  </form>

                  <form method="POST" action="/users/{{this.id}}/status">
                    <input type="hidden" name="isEnabled" value="{{#if this.isEnabled}}false{{else}}true{{/if}}" />
                    <button
                      type="submit"
                      class="rounded-lg border px-3 py-2 text-sm font-semibold {{#if this.isEnabled}}border-red-300 bg-red-100 text-red-700 hover:bg-red-200{{else}}border-green-300 bg-green-100 text-green-700 hover:bg-green-200{{/if}}"
                    >
                      {{#if this.isEnabled}}Disable{{else}}Enable{{/if}}
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="4" class="px-4 py-6 text-center text-slate-500">No users found.</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</section>