<section class="space-y-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
  <header class="flex flex-col gap-6 border-b border-slate-100 pb-6 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Access</p>
      <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">{{title}}</h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">
        Admins can assign <strong>Admin</strong> or <strong>Technician</strong> roles and enable/disable sign-in without deleting audit history.
      </p>
    </div>
    <a
      class="inline-flex shrink-0 items-center justify-center rounded-lg bg-brand-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-900"
      href="/users/new"
    >
      Create user
    </a>
  </header>

  <div class="overflow-hidden rounded-xl border border-slate-200 shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-[640px] w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wider text-slate-600">
          <tr>
            <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Email</th>
            <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Role</th>
            <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Account</th>
            <th scope="col" class="whitespace-nowrap px-4 py-3 lg:px-5">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          {{#if users.length}}
            {{#each users}}
              <tr class="transition-colors hover:bg-slate-50/90">
                <td class="px-4 py-3.5 text-slate-900 lg:px-5">{{this.email}}</td>
                <td class="px-4 py-3.5 text-slate-700 lg:px-5">
                  {{#if (eq this.role "admin")}}
                    <span class="inline-flex rounded-full bg-violet-50 px-2.5 py-0.5 text-xs font-semibold text-violet-800 ring-1 ring-violet-200">Admin</span>
                  {{else}}
                    <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">Technician</span>
                  {{/if}}
                </td>
                <td class="px-4 py-3.5 lg:px-5">
                  {{#if this.isEnabled}}
                    <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-800 ring-1 ring-emerald-200">Enabled</span>
                  {{else}}
                    <span class="inline-flex rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-800 ring-1 ring-red-200">Disabled</span>
                  {{/if}}
                </td>
                <td class="min-w-[16rem] px-4 py-3 lg:px-5">
                  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-start">
                    <form method="POST" action="/users/{{this.id}}/role" class="flex flex-1 flex-col gap-2 sm:min-w-[200px] sm:flex-row sm:items-center">
                      <select
                        name="role"
                        class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm outline-none focus:border-brand-700 focus:ring-2 focus:ring-brand-500/20 sm:max-w-[9rem]"
                        required
                        aria-label="Role for {{this.email}}"
                      >
                        <option value="admin" {{#if (eq this.role "admin")}}selected{{/if}}>Admin</option>
                        <option value="technician" {{#if (eq this.role "technician")}}selected{{/if}}>Technician</option>
                      </select>
                      <button
                        type="submit"
                        class="whitespace-nowrap rounded-lg border border-amber-200 bg-white px-3 py-2 text-xs font-semibold text-amber-900 shadow-sm hover:bg-amber-50"
                      >
                        Update role
                      </button>
                    </form>

                    <form method="POST" action="/users/{{this.id}}/status">
                      <input type="hidden" name="isEnabled" value="{{#if this.isEnabled}}false{{else}}true{{/if}}" />
                      <button
                        type="submit"
                        class="rounded-lg px-3 py-2 text-xs font-semibold shadow-sm {{#if this.isEnabled}}border border-red-200 bg-white text-red-700 hover:bg-red-50{{else}}border border-emerald-200 bg-white text-emerald-800 hover:bg-emerald-50{{/if}}"
                      >
                        {{#if this.isEnabled}}Disable{{else}}Enable{{/if}}
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            {{/each}}
          {{else}}
            <tr>
              <td colspan="4" class="px-6 py-14 text-center text-sm text-slate-500">No user accounts matched this view.</td>
            </tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </div>
</section>
